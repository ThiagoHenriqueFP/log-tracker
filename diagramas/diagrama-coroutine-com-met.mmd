graph TD
  %% Diagrama em duas colunas (vertical e compacto)
  subgraph Coluna1[Fluxo principal]
    direction TB
    REQ["Request HTTP / Kafka\n(início)"]
    TP["Thread Principal\n(MDC inicializado)"]
    LAUNCH["launchWithMdc()\n(CoroutineMdcExtensions)"]
    WORKER["Worker (Dispatcher)\n(MDC preservado)"]
    LOGS["Logs finais\n(correlationId + optional correlationIdInternal)"]
  end

  subgraph Coluna2["Sub-contextos"]
    direction TB
    SUBMGR["MdcSubContextManager\n(cria correlationIdInternal, DEPTH)"]
    SUB["Sub-contexto\n(correlationIdInternal)\nexecuta bloco em novo scope"]
    REST["Restaura MDC original\n(após sub-contexto)"]
  end

  %% Ligações principais (coluna 1)
  REQ --> TP --> LAUNCH --> WORKER --> LOGS

  %% Conexões entre colunas: worker cria/aciona sub-contextos
  WORKER -.-> SUBMGR
  SUBMGR --> SUB --> REST --> LOGS

classDef gray fill:#f3f4f6,stroke:#bbb
class Coluna1,Coluna2 gray
%% Notas compactas para referência de código
%% MdcContextElement: updateThreadContext() aplica mapa MDC na thread; restoreThreadContext() restaura mapa anterior
%% MdcSubContextManager: cria SUB_CONTEXT_ID, DEPTH, SUB_CONTEXT_NAME; executa bloco com launchWithMdc() e restaura MDC original

