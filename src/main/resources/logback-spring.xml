<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <property name="LOG_FILE" value="logs/distributed-logging.log"/>
    <property name="LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n"/>
    <property name="LOG_MAX_FILE_SIZE" value="10MB"/>
    <property name="LOG_MAX_HISTORY" value="30"/>
    <property name="LOG_TOTAL_SIZE_CAP" value="1GB"/>

    <!-- Appender de Console para desenvolvimento -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>{"application":"distributed-logging","environment":"dev"}</customFields>
            <includeContext>true</includeContext>
            <fieldNames>
                <timestamp>@timestamp</timestamp>
                <message>message</message>
                <logger>logger</logger>
                <level>level</level>
                <caller>caller</caller>
                <stackTrace>stackTrace</stackTrace>
            </fieldNames>

            <shortenedLoggerNameLength>20</shortenedLoggerNameLength>
        </encoder>
    </appender>

    <!-- Appender JSON de Arquivo com Rotação -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_FILE}</file>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>{"application":"distributed-logging"}</customFields>
            <includeContext>true</includeContext>
            <fieldNames>
                <timestamp>@timestamp</timestamp>
                <message>message</message>
                <logger>logger</logger>
                <level>level</level>
                <caller>caller</caller>
                <stackTrace>stackTrace</stackTrace>
            </fieldNames>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>logs/distributed-logging-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>${LOG_MAX_FILE_SIZE}</maxFileSize>
            <maxHistory>${LOG_MAX_HISTORY}</maxHistory>
            <totalSizeCap>${LOG_TOTAL_SIZE_CAP}</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- Appender JSON para Logs de Erro -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/distributed-logging-error.log</file>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>{"application":"distributed-logging","severity":"error"}</customFields>
            <includeContext>true</includeContext>
            <includeContextName>true</includeContextName>
            <fieldNames>
                <timestamp>@timestamp</timestamp>
                <message>message</message>
                <logger>logger</logger>
                <level>level</level>
                <caller>caller</caller>
                <stackTrace>stackTrace</stackTrace>
                <mdc>mdc</mdc>
            </fieldNames>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>logs/distributed-logging-error-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>${LOG_MAX_FILE_SIZE}</maxFileSize>
            <maxHistory>${LOG_MAX_HISTORY}</maxHistory>
            <totalSizeCap>${LOG_TOTAL_SIZE_CAP}</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- Logger para a aplicação -->
    <logger name="br.edu.ufersa.distributed_logging" level="DEBUG"/>

    <!-- Logger para Spring Framework -->
    <logger name="org.springframework" level="INFO"/>
    <logger name="org.springframework.boot" level="INFO"/>
    <logger name="org.springframework.kafka" level="INFO"/>

    <!-- Logger para Kafka -->
    <logger name="org.apache.kafka" level="WARN"/>

    <!-- Logger para Micrometer Tracing (Distributed Tracing) -->
    <logger name="io.micrometer.tracing" level="INFO"/>
    <logger name="brave" level="INFO"/>

    <!-- Logger para Jackson -->
    <logger name="com.fasterxml.jackson" level="WARN"/>

    <!-- Profile de Desenvolvimento -->
    <springProfile name="dev,default">
        <root level="DEBUG">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
            <appender-ref ref="ERROR_FILE"/>
        </root>
    </springProfile>

    <!-- Profile de Produção -->
    <springProfile name="prod">
        <root level="INFO">
            <appender-ref ref="FILE"/>
            <appender-ref ref="ERROR_FILE"/>
        </root>
    </springProfile>

    <!-- Profile de Teste -->
    <springProfile name="test">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

</configuration>

